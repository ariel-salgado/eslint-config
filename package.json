{
  "name": "@ariel-salgado/eslint-config",
  "type": "module",
  "version": "1.0.0",
  "description": "Eslint config for @ariel-salgado.",
  "author": "Ariel Salgado <ariel.salgado.acevedo@gmail.com> (https://github.com/ariel-salgado/)",
  "license": "MIT",
  "homepage": "https://github.com/ariel-salgado/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ariel-salgado/eslint-config.git"
  },
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build:typegen && tsdown",
    "build:typegen": "bun run scripts/typegen.ts",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "check": "tsc --noEmit",
    "prepare": "simple-git-hooks",
    "release": "sh ./scripts/release.sh",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "eslint-plugin-better-tailwindcss": ">=4.5.0",
    "eslint-plugin-svelte": "^3.10.1",
    "svelte-eslint-parser": "^1.2.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-better-tailwindcss": {
      "optional": true
    },
    "eslint-plugin-svelte": {
      "optional": true
    },
    "svelte-eslint-parser": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "1.1.0",
    "@clack/prompts": "1.3.0",
    "@e18e/eslint-plugin": "0.4.1",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint/markdown": "8.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vitest/eslint-plugin": "1.6.16",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-flat-config-utils": "3.2.0",
    "eslint-merge-processors": "2.0.0",
    "eslint-plugin-ariel": "0.1.2",
    "eslint-plugin-de-morgan": "2.1.1",
    "eslint-plugin-import-lite": "0.6.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-jsonc": "3.1.2",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-perfectionist": "5.9.0",
    "eslint-plugin-pnpm": "1.6.0",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-toml": "1.3.1",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-yml": "3.3.2",
    "find-up-simple": "1.0.1",
    "globals": "17.6.0",
    "local-pkg": "1.1.2",
    "toml-eslint-parser": "1.0.3",
    "yaml-eslint-parser": "2.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.2",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260502.1",
    "bumpp": "11.0.1",
    "eslint": "10.3.0",
    "eslint-plugin-better-tailwindcss": "4.5.0",
    "eslint-plugin-erasable-syntax-only": "0.4.1",
    "eslint-plugin-svelte": "3.17.1",
    "eslint-typegen": "2.3.1",
    "lint-staged": "16.4.0",
    "publint": "0.3.18",
    "simple-git-hooks": "2.13.1",
    "svelte": "5.55.5",
    "svelte-eslint-parser": "1.6.0",
    "tailwindcss": "4.2.4",
    "tsdown": "0.21.10",
    "typescript": "6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "inlinedDependencies": {
    "@eslint-community/eslint-utils": "4.9.1",
    "@typescript-eslint/scope-manager": "8.59.1",
    "@typescript-eslint/types": "8.59.1",
    "@typescript-eslint/utils": "8.59.1",
    "@typescript-eslint/visitor-keys": "8.59.1",
    "cached-factory": "0.2.0",
    "eslint-plugin-erasable-syntax-only": "0.4.1",
    "eslint-visitor-keys": [
      "3.4.3",
      "5.0.1"
    ]
  }
}
